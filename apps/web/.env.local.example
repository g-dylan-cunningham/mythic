# Choose which Supabase project the app should use.
# development = hosted Supabase dev project
# local = Docker-based local Supabase stack from `npm run supabase:start`
NEXT_PUBLIC_SUPABASE_TARGET=development

# Hosted development project.
NEXT_PUBLIC_SUPABASE_DEV_URL=
NEXT_PUBLIC_SUPABASE_DEV_PUBLISHABLE_KEY=

# Local project. Fill the key from `npm run supabase:status`.
NEXT_PUBLIC_SUPABASE_LOCAL_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_LOCAL_PUBLISHABLE_KEY=

# Backward-compatible fallback names. New setup should prefer the target-specific
# variables above.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Printavo API credentials. Never prefix these with NEXT_PUBLIC_.
PRINTAVO_API_BASE_URL=https://www.printavo.com
PRINTAVO_API_VERSION=v1
PRINTAVO_API_EMAIL=
PRINTAVO_API_TOKEN=

# Server-only S&S Activewear API credentials. Never prefix these with NEXT_PUBLIC_.
# S&S uses HTTP Basic Auth: username = account number, password = API key.
SS_API_BASE_URL=https://api.ssactivewear.com
SS_API_VERSION=v2
SS_ACCOUNT_NUMBER=
SS_API_KEY=
SS_TEST_SKU=B00760004
SS_REPORT_PART_NUMBER=00760
